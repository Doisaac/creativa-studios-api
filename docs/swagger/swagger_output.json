{
  "swagger": "2.0",
  "info": {
    "title": "Creativa Studios API",
    "description": "API documentation for Creativa Studios",
    "version": "1.0.0"
  },
  "host": "localhost:4000",
  "basePath": "/",
  "tags": [
    {
      "name": "Auth",
      "description": "Autenticación"
    },
    {
      "name": "Health",
