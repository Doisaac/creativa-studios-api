                "nombre": {
                  "type": "string",
                  "example": "Camisas Talla S blanco 100% algodón"
                },
                "stock_minimo": {
                  "type": "number",
                  "example": 12
                },
                "unidad_de_medida": {
                  "type": "string",
                  "example": "Unidades"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      },
      "delete": {
        "tags": [
          "Inventario"
        ],
        "summary": "Eliminar inventario si no tiene referencias",
        "description": "",
        "parameters": [
          {
