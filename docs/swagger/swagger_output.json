            "schema": {
              "type": "object",
              "properties": {
                "nombre": {
                  "type": "string",
                  "example": "Camisas Talla S blanco 100% algodón"
                },
                "stock_actual": {
                  "type": "number",
                  "example": 25
                },
                "stock_minimo": {
                  "type": "number",
                  "example": 10
                },
                "unidad_de_medida": {
                  "type": "string",
                  "example": "Unidades"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      },
      "get": {
        "tags": [
          "Inventario"
        ],
        "summary": "Listar inventario",
