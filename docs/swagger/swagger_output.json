      "get": {
        "tags": [
          "Health"
        ],
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Crear usuario para utilizar el sistema",
        "description": "",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "nombre": {
                  "type": "string",
                  "example": "Douglas Barrera"
                },
                "email": {
                  "type": "string",
                  "example": "douglas@creativa.com"
                },
                "contraseña": {
                  "type": "string",
                  "example": "password123"
                },
                "rol": {
                  "type": "string",
                  "example": "ADMIN | RECEPCION | PRODUCCION | INSTALADOR"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Iniciar sesión en el sistema",
        "description": "",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "email": {
                  "example": "any"
                },
                "contrasena": {
                  "example": "any"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/auth/renew": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Renovar token de autenticación",
        "description": "",
        "parameters": [
          {
            "name": "x-token",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/inventario/": {
      "post": {
        "tags": [
          "Inventario"
        ],
        "summary": "Crear insumo/material de inventario",
        "description": "",
