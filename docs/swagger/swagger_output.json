    "/api/inventario/{id}": {
      "get": {
        "tags": [
          "Inventario"
        ],
        "summary": "Obtener inventario por id",
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "x-token",
