{
  "name": "creativa-studios-api",
  "version": "1.0.0",
  "type": "module",
  "description": "An API for Creativa Studios",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "format": "prettier --write \"src/**/*\"",
    "lint": "eslint .",
    "build": "tsc"
  },
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "imports": {
    "#src/*": "./src/*"
  },
  "dependencies": {
    "express": "5.2.1",
    "morgan": "1.10.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/recommended": "^1.0.13",
    "@types/express": "5.0.6",
    "@types/morgan": "^1.9.10",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  }
}
